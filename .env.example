# ── API Tokens ───────────────────────────────────────────────
HF_TOKEN=your_huggingface_token_here

# Optional: for generating training data via LLM
# GLM_API_KEY=your_glm_api_key_here
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Base Model ───────────────────────────────────────────────
MODEL_NAME=Qwen/Qwen2.5-Coder-3B-Instruct

# ── Training (adjust for your GPU) ──────────────────────────
# 8GB GPU (RTX 3070 Ti):  seq=1024, r=16, accum=4
# 16GB GPU (RTX 4080):    seq=2048, r=32, accum=8
# 24GB GPU (RTX 4090):    seq=2048, r=32, accum=8
# 40GB GPU (A100):        seq=4096, r=32, accum=8
MAX_SEQ_LENGTH=1024
LORA_R=16
LORA_ALPHA=16
NUM_TRAIN_EPOCHS=3
LEARNING_RATE=2e-4
GRADIENT_ACCUMULATION_STEPS=4
PER_DEVICE_TRAIN_BATCH_SIZE=1

# ── Output ───────────────────────────────────────────────────
OUTPUT_DIR=outputs/qwen-go-lora
